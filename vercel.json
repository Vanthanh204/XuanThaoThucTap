{
    "version": 2,
    "installCommand": "exit 0",
    "buildCommand": "exit 0",
    "outputDirectory": "public",
    "functions": {
        "api/index.php": { "runtime": "vercel-php@0.9.0" }
    },
    "routes": [
        {
            "src": "/(css|js|images|admin|clients|build|vendors|assets)/(.*)",
            "dest": "/$1/$2"
        },
        {
            "src": "/(favicon.ico|robots.txt)",
            "dest": "/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "false",
        "LOG_CHANNEL": "stderr",
        "SESSION_DRIVER": "cookie"
    }
}
